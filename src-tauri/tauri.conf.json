{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "e-voice",
  "version": "0.1.0",
  "identifier": "com.e-voice.app",
  "build": {
    "beforeDevCommand": "npm run dev --prefix src-frontend",
    "beforeBuildCommand": "npm run build --prefix src-frontend",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../src-frontend/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "e-voice",
        "width": 900,
        "height": 650,
        "minWidth": 600,
        "minHeight": 400,
        "visible": true,
        "decorations": true,
        "closable": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {},
    "externalBin": [],
    "copyright": "",
    "category": "Utility",
    "shortDescription": "LLM-powered dictation post-processor",
    "longDescription": "e-voice is an LLM-powered post-processor for speech-to-text output.",
    "linux": {
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  }
}
